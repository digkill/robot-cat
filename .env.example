# S3 хранилище (Beget)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=ru1
AWS_BUCKET=your-bucket-name
AWS_ENDPOINT=https://s3.ru1.storage.beget.cloud
AWS_USE_PATH_STYLE_ENDPOINT=true

# LLM API (OpenAI-совместимый)
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=your_api_key
LLM_MODEL=gpt-4o-mini

# Слушать ответы: сек записи, мин. символов для ответа
LISTEN_DURATION=6
LISTEN_MIN_TEXT=2

# Серия снимков при движении: 1 кадр в секунду, сек
MOTION_RECORD_SEC=5
MOTION_GREETING_ENABLED=true
MOTION_GREETING_TEXT=Привет! Как дела?


# Звук: default = через PipeWire
AUDIO_DEVICE=default

# TTS: provider = openai | auto | espeak | gtts
TTS_PROVIDER=openai

# OpenAI TTS
# Варианты голосов: alloy, ash, ballad, coral, echo, fable, nova, onyx, sage, shimmer, verse, marin, cedar
TTS_OPENAI_MODEL=gpt-4o-mini-tts
TTS_OPENAI_VOICE=alloy

# Локальный fallback (espeak)
# Примеры голосов: ru, en, en-us, en-gb, de, fr-fr, es, pl
TTS_VOICE=ru
TTS_SPEED=120
TTS_VOLUME=200

# Персонаж, который говорит
# Варианты: robot_cat, assistant, guard, professor, pirate
ASSISTANT_CHARACTER=robot_cat

# Wake word (локально, без токенов)
WAKE_WORD_ENABLED=false
WAKE_WORD_PHRASE=Hello Kitty
WAKE_WORD_CHUNK_SEC=2.0
WAKE_WORD_COOLDOWN=6.0
